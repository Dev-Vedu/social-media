{
  "info": {
    "name": "Social API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "postId",  "value": "1" }
  ],
  "item": [
    {
      "name": "1. Create Post (by User)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/api/posts", "host": ["{{baseUrl}}"], "path": ["api","posts"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorId\": 1,\n  \"authorType\": \"USER\",\n  \"content\": \"Hello this is my first post!\"\n}"
        }
      }
    },
    {
      "name": "2. Create Post (by Bot)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/api/posts", "host": ["{{baseUrl}}"], "path": ["api","posts"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorId\": 1,\n  \"authorType\": \"BOT\",\n  \"content\": \"Bot generated post content.\"\n}"
        }
      }
    },
    {
      "name": "3. Add Human Comment",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/api/posts/{{postId}}/comments", "host": ["{{baseUrl}}"], "path": ["api","posts","{{postId}}","comments"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorId\": 1,\n  \"authorType\": \"USER\",\n  \"content\": \"Nice post!\"\n}"
        }
      }
    },
    {
      "name": "4. Add Bot Comment (first time - should work)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/api/posts/{{postId}}/comments", "host": ["{{baseUrl}}"], "path": ["api","posts","{{postId}}","comments"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorId\": 1,\n  \"authorType\": \"BOT\",\n  \"content\": \"Bot says hi!\"\n}"
        }
      }
    },
    {
      "name": "5. Add Bot Comment (second time - should get 429 cooldown)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/api/posts/{{postId}}/comments", "host": ["{{baseUrl}}"], "path": ["api","posts","{{postId}}","comments"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorId\": 1,\n  \"authorType\": \"BOT\",\n  \"content\": \"Bot trying again!\"\n}"
        }
      }
    },
    {
      "name": "6. Like a Post",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/api/posts/{{postId}}/like", "host": ["{{baseUrl}}"], "path": ["api","posts","{{postId}}","like"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": 1,\n  \"authorType\": \"USER\"\n}"
        }
      }
    }
  ]
}
